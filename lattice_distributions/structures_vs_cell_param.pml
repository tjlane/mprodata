

bg white

set all_states, on
dss

set cartoon_oval_length, 0.5
set cartoon_oval_width, 0.2

set cartoon_rect_length, 1.0

run spectrum_states.py
spectrum_states *, cartoon, blue lime
spectrum_states *, ribbon, blue lime

as ribbon

set ray_trace_mode, 1

# --------

# global view
set_view (\
    -0.138019398,    0.239327729,   -0.961073279,\
    -0.964869499,   -0.251474261,    0.075939372,\
    -0.223517105,    0.937801421,    0.265626520,\
     0.000030056,    0.000067323, -224.387313843,\
     9.385807991,    3.316119194,    0.491785526,\
    91.193588257,  357.505157471,  -20.000000000 )
ray 2048, 2048
save global_view.png


